  "recipeSteps": [
    {
      "id": 1,
      "recipeId": 1,
      "stepNumber": 1,
      "instruction": "후라이팬에 기름을 두르고 김치를 볶는다."
    },
    {
      "id": 2,
      "recipeId": 1,
      "stepNumber": 2,
      "instruction": "김치를 볶고 가장자리에 간장 1스푼을 넣고 태운다."
    },
    {
      "id": 3,
      "recipeId": 1,
      "stepNumber": 3,
      "instruction": "밥을 넣고 고슬고슬하게 볶는다."
    },
    {
      "id": 4,
      "recipeId": 1,
      "stepNumber": 4,
      "instruction": "소금으로 간을 맞춘다."
    },
    {
      "id": 5,
      "recipeId": 1,
      "stepNumber": 5,
      "instruction": "불을 끄고 김가루와 깨를 뿌리고 맛있게 먹는다."
    },
    {
      "id": 6,
      "recipeId": 2,
      "stepNumber": 1,
      "instruction": "계란을 그릇에 풀고 소금으로 간을 한다."
    },
    {
      "id": 7,
      "recipeId": 2,
      "stepNumber": 2,
      "instruction": "대파와 당근을 잘게 다져 푼 계란에 섞는다."
    },
    {
      "id": 8,
      "recipeId": 2,
      "stepNumber": 3,
      "instruction": "팬에 기름을 두르고 달군 뒤 계란물을 조금씩 부어가며 말아준다."
    },
    {
      "id": 9,
      "recipeId": 2,
      "stepNumber": 4,
      "instruction": "먹기 좋은 크기로 썰어 완성한다."
    },
    {
      "id": 10,
      "recipeId": 3,
      "stepNumber": 1,
      "instruction": "돼지고기를 고추장, 설탕 등으로 양념하여 재워둔다."
    },
    {
      "id": 11,
      "recipeId": 3,
      "stepNumber": 2,
      "instruction": "팬에 식용유를 두르고 양념한 고기를 볶는다."
    },
    {
      "id": 12,
      "recipeId": 3,
      "stepNumber": 3,
      "instruction": "고기가 익어갈 때 양파와 대파를 넣고 함께 볶는다."
    },
    {
      "id": 13,
      "recipeId": 3,
      "stepNumber": 4,
      "instruction": "그릇에 밥을 담고 볶은 제육을 올려 완성한다."
    },
    {
      "id": 14,
      "recipeId": 4,
      "stepNumber": 1,
      "instruction": "냄비에 김치와 돼지고기를 넣고 볶는다."
    },
    {
      "id": 15,
      "recipeId": 4,
      "stepNumber": 2,
      "instruction": "물을 붓고 끓이다가 썰어둔 두부와 대파를 넣는다."
    },
    {
      "id": 16,
      "recipeId": 4,
      "stepNumber": 3,
      "instruction": "국물이 진해질 때까지 푹 끓여 완성한다."
    },
    {
      "id": 17,
      "recipeId": 5,
      "stepNumber": 1,
      "instruction": "냄비에 물을 붓고 된장을 풀어 끓인다."
    },
    {
      "id": 18,
      "recipeId": 5,
      "stepNumber": 2,
      "instruction": "깍둑썰기한 감자와 호박을 넣고 익힌다."
    },
    {
      "id": 19,
      "recipeId": 5,
      "stepNumber": 3,
      "instruction": "마지막에 두부와 대파를 넣고 한소끔 더 끓여 완성한다."
    }
  ],
